<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hstk.iot_warehouse.mapper.IotSwitchLogMapper">
    <resultMap id="BaseResultMap" type="com.hstk.iot_warehouse.model.entity.IotSwitchLog">
        <id column="log_id" property="logId" />
        <result column="device_id" property="deviceId" />
        <result column="component_name" property="componentName" />
        <result column="action" property="action" />
        <result column="status" property="status" />
        <result column="trigger_source" property="triggerSource" />
        <result column="user_id" property="userId" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <insert id="insert" parameterType="com.hstk.iot_warehouse.model.entity.IotSwitchLog" useGeneratedKeys="true" keyProperty="logId">
        INSERT INTO iot_switch_log (device_id, component_name, action, status, trigger_source, user_id, create_time)
        VALUES (#{deviceId}, #{componentName}, #{action}, #{status}, #{triggerSource}, #{userId}, #{createTime})
    </insert>

    <update id="update" parameterType="com.hstk.iot_warehouse.model.entity.IotSwitchLog">
        UPDATE iot_switch_log
        <set>
            <if test="action != null">action = #{action},</if>
            <if test="status != null">status = #{status},</if>
            <if test="triggerSource != null">trigger_source = #{triggerSource},</if>
        </set>
        WHERE log_id = #{logId}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM iot_switch_log WHERE log_id = #{logId}
    </delete>

    <select id="selectById" resultMap="BaseResultMap" parameterType="long">
        SELECT * FROM iot_switch_log WHERE log_id = #{logId}
    </select>

    <select id="selectByDeviceAndComponent" resultMap="BaseResultMap">
        SELECT * FROM iot_switch_log 
        WHERE device_id = #{deviceId} 
        AND component_name = #{componentName} 
        ORDER BY create_time DESC
    </select>

    <select id="selectRecent" resultMap="BaseResultMap" parameterType="int">
        SELECT * FROM iot_switch_log ORDER BY create_time DESC LIMIT #{limit}
    </select>

    <select id="selectByDeviceId" resultMap="BaseResultMap">
        SELECT * FROM iot_switch_log 
        WHERE device_id = #{deviceId} 
        ORDER BY create_time DESC 
        LIMIT #{limit}
    </select>
</mapper>