<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hstk.iot_warehouse.mapper.IotDeviceMapper">
    <resultMap id="BaseResultMap" type="com.hstk.iot_warehouse.model.entity.IotDevice">
        <id column="device_id" property="deviceId" />
        <result column="device_name" property="deviceName" />
        <result column="device_type" property="deviceType" />
        <result column="location" property="location" />
        <result column="status" property="status" />
        <result column="owner_id" property="ownerId" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <insert id="insert" parameterType="com.hstk.iot_warehouse.model.entity.IotDevice">
        INSERT INTO iot_device (device_id, device_name, device_type, location, status, owner_id, create_time)
        VALUES (#{deviceId}, #{deviceName}, #{deviceType}, #{location}, #{status}, #{ownerId}, #{createTime})
    </insert>

    <update id="update" parameterType="com.hstk.iot_warehouse.model.entity.IotDevice">
        UPDATE iot_device
        <set>
            <if test="deviceName != null">device_name = #{deviceName},</if>
            <if test="deviceType != null">device_type = #{deviceType},</if>
            <if test="location != null">location = #{location},</if>
            <if test="status != null">status = #{status},</if>
            <if test="ownerId != null">owner_id = #{ownerId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </set>
        WHERE device_id = #{deviceId}
    </update>

    <delete id="deleteById" parameterType="String">
        DELETE FROM iot_device WHERE device_id = #{deviceId}
    </delete>

    <select id="selectById" resultMap="BaseResultMap" parameterType="String">
        SELECT * FROM iot_device WHERE device_id = #{deviceId}
    </select>

    <select id="selectByNormalizedId" resultMap="BaseResultMap" parameterType="String">
        SELECT *
        FROM iot_device
        WHERE UPPER(REPLACE(REPLACE(REPLACE(REPLACE(device_id, ':', ''), '-', ''), '.', ''), ' ', '')) = #{normalizedDeviceId}
        LIMIT 1
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM iot_device
    </select>
    <select id="selectByOwnerId" resultMap="BaseResultMap" parameterType="java.lang.Long">
        SELECT d.* 
        FROM iot_device d
        JOIN iot_device_user du ON d.device_id = du.device_id
        WHERE du.user_id = #{ownerId}
    </select>

    <!-- Check if relationship exists -->
    <select id="checkAssignment" resultType="int">
        SELECT COUNT(*) FROM iot_device_user 
        WHERE device_id = #{deviceId} AND user_id = #{userId}
    </select>
    
    <!-- Add assignment -->
    <insert id="assignDevice">
        INSERT INTO iot_device_user (device_id, user_id, create_time)
        VALUES (#{deviceId}, #{userId}, NOW())
    </insert>
    
    <!-- Remove assignment -->
    <delete id="unassignDevice">
        DELETE FROM iot_device_user 
        WHERE device_id = #{deviceId} AND user_id = #{userId}
    </delete>

    <!-- Get list of user IDs assigned to a device -->
    <select id="getAssignedUserIds" resultType="long">
        SELECT user_id FROM iot_device_user WHERE device_id = #{deviceId}
    </select>
</mapper>
